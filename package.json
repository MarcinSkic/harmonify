{
  "name": "harmonify",
  "type": "module",
  "version": "3.2.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel -A vercel.local.json dev",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "UID=$(id -u) GID=$(id -g) docker compose -f docker-compose.e2e.yml run --rm e2e",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/file-saver": "^2.0.7",
    "@vueuse/core": "^14.2.1",
    "audiomotion-analyzer": "^4.5.4",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color-convert": "^3.1.3",
    "dexie": "^4.4.1",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.11.13",
    "lucide-vue-next": "^0.483.0",
    "papaparse": "^5.5.3",
    "pinia": "^3.0.4",
    "query-string": "^9.3.1",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "universal-cookie": "^8.0.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.19.15",
    "@types/papaparse": "^5.5.2",
    "@vercel/node": "^5.6.18",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^10.1.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-format": "^2.0.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^8.0.8",
    "vite-plugin-vercel": "^11.0.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
